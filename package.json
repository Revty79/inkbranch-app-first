{
  "name": "inkbranch",
  "version": "0.1.0",
  "private": true,
  "description": "App-first interactive fiction foundation for Inkbranch.",
  "workspaces": [
    "apps/mobile",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm run start --workspace apps/mobile",
    "dev:server": "npm run dev --workspace server",
    "check:story-progression": "tsx scripts/check-saltglass-progression.ts",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "tsx": "^4.22.4"
  }
}
